rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isCompany() {
      return signedIn() && exists(/databases/$(database)/documents/companies/$(request.auth.uid));
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /students/{uid} {
      allow create: if isOwner(uid);
      allow get, update: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow delete: if false;
    }

    match /applications/{applicationId} {
      allow create: if signedIn()
        && !isAdmin()
        && request.resource.data.studentId == request.auth.uid;
      allow get: if isAdmin()
        || (signedIn() && resource.data.studentId == request.auth.uid)
        || (isCompany() && resource.data.companyId == request.auth.uid);
      allow list: if isAdmin()
        || (signedIn() && resource.data.studentId == request.auth.uid)
        || (isCompany() && resource.data.companyId == request.auth.uid);
      allow update: if isAdmin()
        || (isCompany() && resource.data.companyId == request.auth.uid);
      allow delete: if false;
    }

    match /vacancies/{vacancyId} {
      allow get, list: if signedIn();
      allow create: if isAdmin() || isCompany();
      allow update, delete: if isAdmin()
        || (isCompany() && resource.data.companyId == request.auth.uid);
    }

    match /admins/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /companies/{uid} {
      allow create: if isOwner(uid);
      allow get, update: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow delete: if false;
    }
  }
}
