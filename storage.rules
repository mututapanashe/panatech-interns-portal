rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isStudentOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isValidCvUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');
    }

    match /student-cvs/{uid}/{allPaths=**} {
      allow read: if isStudentOwner(uid) || isAdmin();
      allow create, update: if isStudentOwner(uid) && isValidCvUpload();
      allow delete: if isStudentOwner(uid);
    }
  }
}
